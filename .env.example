# ── Shopify App Credentials ──────────────────────────────────────────────────
# Get these from your Shopify Partner Dashboard → Apps → Your App → App setup
SHOPIFY_API_KEY=your_api_key_here
SHOPIFY_API_SECRET=your_api_secret_here

# ── App URL ──────────────────────────────────────────────────────────────────
# The public HTTPS URL where this app is hosted (no trailing slash)
# For local dev, use ngrok: https://abc123.ngrok.io
SHOPIFY_APP_URL=https://your-app-domain.com

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Google PageSpeed Insights (optional) ─────────────────────────────────────
# Get a free key at: https://developers.google.com/speed/docs/insights/v5/get-started
# Without this key, AppLens uses lightweight heuristic scoring instead.
PAGESPEED_API_KEY=
